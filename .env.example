# Required: bot token from https://discord.com/developers/applications
#   → Your App → Bot tab → "Reset Token"
# Treat as a secret. Never commit .env.
DISCORD_BOT_TOKEN=

# Required: numeric application ID, found at the top of "General Information".
DISCORD_APPLICATION_ID=

# Optional: server (guild) ID for guild-scoped slash command sync.
# Right-click your server name (with Developer Mode on) → "Copy Server ID".
# Leave blank for global sync (≈1 hour propagation).
DISCORD_GUILD_ID=

# Optional: channel ID used to seed the first agent's channel subscription
# on first boot (fallback for the per-agent
# CALFKIT_AGENT_<NAME>_BOOTSTRAP_CHANNELS var).
# Right-click any channel (with Developer Mode on) → "Copy Channel ID".
DISCORD_DEFAULT_CHANNEL_ID=

# Optional: numeric user ID of the human owner.
# Right-click your own user (with Developer Mode on) → "Copy User ID".
# The bridge normalizer uses this to tag inbound messages from the owner.
DISCORD_OWNER_USER_ID=

# ── Model provider credentials ──────────────────────────────────────────
# Every agent picks a provider in its frontmatter (``provider:`` — one of
# "anthropic", "openai", or "openai-codex"). Supply the key(s) for the
# provider(s) your agents actually use; the model SDKs read these standard
# env vars on first invocation, so a missing key surfaces only when an agent
# runs, not at startup. The default provider is "anthropic".

# Required when any agent uses ``provider: anthropic`` (the default provider).
ANTHROPIC_API_KEY=

# Required when any agent uses ``provider: openai``.
OPENAI_API_KEY=

# ``provider: openai-codex`` (ChatGPT Plus/Pro subscription billing) needs no
# API key here — authenticate once with the ``calfkit-auth`` CLI instead.
# See docs/codex-auth.md.

# ── MCP servers ─────────────────────────────────────────────────────────
# MCP servers themselves are NOT configured here — they live in mcp.json
# (default $CALFCORD_HOME/config/mcp.json), managed with ``calfcord mcp add``.
# See docs/mcp-tools.md. This file is only for the SECRETS those entries
# reference: an mcp.json value like "$GITHUB_TOKEN" is expanded from the
# environment when the server starts, so set each referenced var here. They're
# read only by the calfkit-mcp processes (and the ``calfcord mcp`` CLI), never
# by agents — on a distributed deploy these belong on the MCP host only.
#   Example (uncomment + set if your mcp.json references it):
# GITHUB_TOKEN=

# Optional: override the mcp.json path the MCP processes / ``calfcord mcp`` CLI
# read. Resolution: this var → $CALFCORD_HOME/config/mcp.json → ./mcp.json (dev).
# CALFCORD_MCP_CONFIG=

# Kafka bootstrap server URL(s). calfcord speaks the Kafka wire protocol; the
# default local broker is Tansu — a single native binary, no Docker. Pick by how
# you run calfcord:
#   - Native broker:        CALF_HOST_URL=localhost:9092
#                           (start it with ``calfcord broker``). Storage is
#                           ephemeral (memory) — topics/messages reset on broker
#                           restart; calfcord re-creates topics on startup. For
#                           persistence across restarts, start the broker with a
#                           libsql/SQLite store instead of memory (set
#                           STORAGE_ENGINE; see Tansu's docs).
#   - Bring your own Kafka: point CALF_HOST_URL at it (leave unset → "localhost").
#   - Full docker compose:  leave unset; compose's per-service environment block
#                           sets it to tansu:9092.
CALF_HOST_URL=

# Optional: Discord category name to group the unified A2A audit channel
# (default `private-a2a-chats`) under. The calfkit-tools process creates
# the category lazily on first miss and places the audit channel inside
# it. An existing channel is reused regardless of category (move it via
# the Discord UI to backfill). Lock down audit visibility by editing the
# category's permission overwrites; the channel and its threads inherit them.
CALFKIT_A2A_CHANNEL_CATEGORY=

# Path on the calfkit-tools host where the shared agent workspace
# lives. Filesystem (read_file/write_file/edit_file) and search
# (grep/glob) tools resolve relative paths against this dir; the
# shell tool starts here.
#   - Native (default): leave unset → ``<cwd>/state/workspace/``,
#                       created lazily on first call.
#   - Docker compose:   compose's tools service sets this to
#                       ``/workspace`` (bind-mounted from the dedicated
#                       ``./workspace`` scratch dir, NOT the project
#                       root). All agents share the same dir — see
#                       docs/security.md.
CALFCORD_WORKSPACE_DIR=

# Optional: path to a custom memory-explanation prompt for agents with
# `memory: true`. Read by the calfkit-BRIDGE process (the single reader) and
# shipped to agents in `deps`; each memory-enabled agent appends it to its
# instructions and keeps a notepad under `memory/<agent_id>/` in the shared
# workspace via the standard fs tools. Set this on the BRIDGE service. Leave
# unset to use the bundled default
# (src/calfcord/agents/memory_prompt.md). Agents and the tools
# process never read this file.
CALFCORD_MEMORY_PROMPT_PATH=

# Optional: Force a specific shell backend for the `shell` tool. One
# of `tmux` | `subprocess` | `powershell`. Default (unset) auto-detects:
# tmux if installed (persistent state across calls), otherwise
# subprocess (each call independent).
CALFCORD_SHELL_BACKEND=
