# Required: bot token from https://discord.com/developers/applications
#   → Your App → Bot tab → "Reset Token"
# Treat as a secret. Never commit .env.
DISCORD_BOT_TOKEN=

# Required: numeric application ID, found at the top of "General Information".
DISCORD_APPLICATION_ID=

# Optional: server (guild) ID for guild-scoped slash command sync.
# Right-click your server name (with Developer Mode on) → "Copy Server ID".
# Leave blank for global sync (≈1 hour propagation).
DISCORD_GUILD_ID=

# Optional: channel ID used by example scripts.
# Right-click any channel (with Developer Mode on) → "Copy Channel ID".
DISCORD_DEFAULT_CHANNEL_ID=

# Optional: numeric user ID of the human owner.
# Right-click your own user (with Developer Mode on) → "Copy User ID".
# The bridge normalizer uses this to tag inbound messages from the owner.
DISCORD_OWNER_USER_ID=

# Optional: Kafka bootstrap server URL(s). Defaults to "localhost" if unset.
CALF_HOST_URL=

# Optional: Discord category name to group all `a2a-<x>-<y>` audit
# channels under. The calfkit-tools process creates the category lazily
# on first miss and places new A2A channels inside it. Existing channels
# are reused regardless of category (move them via the Discord UI to
# backfill). Lock down audit visibility by editing the category's
# permission overwrites; child channels inherit them.
CALFKIT_A2A_CHANNEL_CATEGORY=
